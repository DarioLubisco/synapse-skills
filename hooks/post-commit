#!/usr/bin/env bash
# post-commit hook para synapse-skills
# Se ejecuta después de cada commit:
#   1. Push a GitHub (origin main)
#   2. Sync skills a Cursor 2.5 (.mdc rules)
set -euo pipefail

REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"

echo ""
echo "=== post-commit: Synapse Skills Auto-Sync ==="

# 1. Push a GitHub
echo "→ Push a GitHub..."
if git -C "$REPO_DIR" remote -v | grep -q origin; then
    git -C "$REPO_DIR" push origin main 2>&1 | sed 's/^/  /' || echo "   ⚠️  Push falló (puede requerir pull primero)"
    echo "✅ GitHub sync completado"
else
    echo "   ⚠️  No hay remote 'origin' configurado. Salteando push."
fi

# 2. Sync a Cursor 2.5
echo "→ Sync a Cursor 2.5..."
if [ -x "$REPO_DIR/scripts/sync-to-cursor.sh" ]; then
    "$REPO_DIR/scripts/sync-to-cursor.sh" 2>&1 | sed 's/^/  /'
    echo "✅ Cursor rules actualizadas"
else
    echo "   ⚠️  sync-to-cursor.sh no encontrado"
fi

echo "=== post-commit completo ==="
echo ""
