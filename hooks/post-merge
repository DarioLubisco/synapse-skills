#!/usr/bin/env bash
# post-merge hook para synapse-skills
# Se ejecuta después de git pull / git merge:
#   1. Verifica si hay cambios nuevos
#   2. Sync skills a Cursor 2.5 (.mdc rules)
set -euo pipefail

REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"

echo ""
echo "=== post-merge: Synapse Skills Auto-Sync ==="

# Verificar si realmente hubo cambios
if git -C "$REPO_DIR" diff --quiet HEAD@{1} HEAD 2>/dev/null; then
    echo "ℹ️  Sin cambios nuevos desde el último commit"
else
    echo "📦 Cambios detectados tras merge/pull"
    
    # 1. Sync a Cursor 2.5
    echo "→ Sync a Cursor 2.5..."
    if [ -x "$REPO_DIR/scripts/sync-to-cursor.sh" ]; then
        "$REPO_DIR/scripts/sync-to-cursor.sh" 2>&1 | sed 's/^/  /'
        echo "✅ Cursor rules actualizadas tras merge"
    else
        echo "   ⚠️  sync-to-cursor.sh no encontrado"
    fi
fi

echo "=== post-merge completo ==="
echo ""
